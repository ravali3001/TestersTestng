<?xml version="1.0" encoding="UTF-8"?>
<!--<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">-->
<suite name="Suite" parallel="tests" thread-count="3">
	<listeners>
		<listener
			class-name="com.aventstack.chaintest.plugins.ChainTestListener" />
		<listener class-name="listeners.TestListener" />
	</listeners>

	<test name="EdgeTest">
		<parameter name="browser" value="edge" />
		<classes>
			<class name="testSuite.HomeTest" />
			<class name="testSuite.RegisterTest" />
			<class name="testSuite.LoginTest" />
			<class name="testSuite.ArrayTest" />
			<class name="testSuite.DataStructuresTest" />
			<class name="testSuite.QueueTest" />
			<class name="testSuite.StackTest" />
		</classes>
	</test>



	<test name="FirefoxTest">
		<parameter name="browser" value="firefox" />
		<classes>
			<class name="testSuite.HomeTest" />
			<class name="testSuite.RegisterTest" />
			<class name="testSuite.LoginTest" />
			<class name="testSuite.ArrayTest" />
			<class name="testSuite.DataStructuresTest" />
			<class name="testSuite.QueueTest" />
			<class name="testSuite.StackTest" />
		</classes>
	</test>

	<test name="ChromeTest">
		<parameter name="browser" value="chrome" />
		<classes>
			<class name="testSuite.HomeTest" />
			<class name="testSuite.RegisterTest" />
			<class name="testSuite.LoginTest" />
			<class name="testSuite.ArrayTest" />
			<class name="testSuite.DataStructuresTest" />
			<class name="testSuite.QueueTest" />
			<class name="testSuite.StackTest" />
		</classes>
	</test>

</suite> 